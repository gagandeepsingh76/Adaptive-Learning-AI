ALA_APP_NAME=AI Learning Assistant API
ALA_APP_VERSION=0.1.0
ALA_ENVIRONMENT=development
ALA_DEBUG=false
ALA_HOST=0.0.0.0
ALA_PORT=8000
ALA_LOG_LEVEL=INFO
ALA_DATABASE_URL=sqlite+aiosqlite:///./data/learning_assistant.db
ALA_DATABASE_ECHO=false
ALA_GEMINI_API_KEY=
ALA_LLM_MODEL=gemini-2.5-flash
ALA_EMBEDDING_MODEL=gemini-embedding-2
ALA_EMBEDDING_DIMENSIONS=768
ALA_LLM_TIMEOUT_SECONDS=45
ALA_EMBEDDING_TIMEOUT_SECONDS=30
ALA_PROVIDER_MAX_ATTEMPTS=3
ALA_AI_TEMPERATURE=0.25
ALA_AI_TOP_P=0.90
ALA_AI_TOP_K=40
ALA_AI_MAX_OUTPUT_TOKENS=8192
ALA_AI_SAFETY_THRESHOLD=BLOCK_MEDIUM_AND_ABOVE
ALA_AI_INPUT_COST_PER_MILLION=0
ALA_AI_OUTPUT_COST_PER_MILLION=0
ALA_AI_METRICS_PATH=./data/ai-metrics.jsonl
ALA_AI_CACHE_PATH=./data/ai-cache.sqlite3
ALA_EMBEDDING_CONCURRENCY=4
ALA_EMBEDDING_DOCUMENT_INSTRUCTION=Represent this learning content for retrieval:
ALA_EMBEDDING_QUERY_INSTRUCTION=Represent this learner question for retrieval:
ALA_CHROMA_PATH=./data/chroma
ALA_CHROMA_COLLECTION_PREFIX=learning_content
ALA_PROMPT_ROOT=app/prompts/templates
ALA_CORS_ALLOWED_ORIGINS=["http://localhost:3000"]
ALA_TRUSTED_HOSTS=["localhost","127.0.0.1"]
ALA_MAX_REQUEST_BYTES=1048576
ALA_ALLOW_ANONYMOUS_LEARNER=true
ALA_ANONYMOUS_LEARNER_ID=00000000-0000-4000-8000-000000000001
ALA_CHUNK_TARGET_TOKENS=400
ALA_CHUNK_MAX_TOKENS=600
ALA_CHUNK_OVERLAP_TOKENS=60
ALA_RETRIEVAL_CANDIDATES=20
ALA_RETRIEVAL_CONTEXT_CHUNKS=8
ALA_RETRIEVAL_MIN_RELEVANCE=0.25
ALA_QUALITY_THRESHOLD=0.80
ALA_RESPONSE_CACHE_TTL_SECONDS=86400
ALA_METRICS_ENABLED=true
